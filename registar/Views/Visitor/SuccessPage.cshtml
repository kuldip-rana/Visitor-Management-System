@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6">
    <div class="max-w-md w-full bg-white rounded-3xl p-10 shadow-xl border border-slate-100 text-center">
        <div class="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
            </svg>
        </div>
        <h2 class="text-2xl font-bold text-slate-800">Registration Complete</h2>
        <p class="text-slate-500 mt-3 leading-relaxed">
            Your email has been verified. Your request is now with the Admin for approval.
            Once approved, you will receive your PDF entry pass at this email address.
        </p>
        <div class="mt-8 border-t border-slate-100 pt-6">
            <a href="@Url.Action("Visitor_Registeration")" class="text-blue-600 font-semibold hover:underline">Register another visit</a>
        </div>
    </div>
</body>
</html>