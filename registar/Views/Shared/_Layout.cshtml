<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Corporate Portal</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <style>
        :root {
            --primary-blue: #2563eb;
            --soft-bg: #f8fafc;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border-color: #e2e8f0;
            --sidebar-width: 260px;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--soft-bg);
            color: var(--text-main);
            margin: 0;
            overflow-x: hidden;
        }

        .main-wrapper {
            display: flex;
            min-height: 100vh;
            width: 100%;
            transition: all 0.3s;
        }

        /* --- Sidebar Logic --- */
        .sidebar {
            width: var(--sidebar-width);
            background: white;
            border-right: 1px solid var(--border-color);
            height: 100vh;
            position: sticky;
            top: 0;
            display: flex;
            flex-direction: column;
            padding: 1.5rem;
            transition: all 0.3s ease;
            z-index: 1000;
        }

            /* Collapsed Sidebar State */
            .sidebar.collapsed {
                margin-left: calc(var(--sidebar-width) * -1);
            }

            .sidebar .nav-link {
                padding: 0.8rem 1rem;
                border-radius: 8px;
                margin-bottom: 0.5rem;
                display: flex;
                align-items: center;
                color: var(--text-main) !important;
                text-decoration: none;
            }

                .sidebar .nav-link:hover {
                    background: var(--soft-bg);
                    color: var(--primary-blue) !important;
                }

        /* --- Toggle Button --- */
        .toggle-btn {
            background: white;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            padding: 5px 10px;
            cursor: pointer;
            margin-bottom: 20px;
            display: inline-block;
            color: var(--text-main);
        }

        .content-area {
            flex-grow: 1;
            padding: 20px;
            min-width: 0; /* Prevents flexbox overflow */
        }

        /* Horizontal Navbar */
        .navbar {
            background-color: #ffffff !important;
            border-bottom: 1px solid var(--border-color);
            padding: 0.8rem 0;
        }

        .btn-register {
            background-color: var(--primary-blue);
            color: white !important;
            padding: 0.5rem 1.2rem;
            border-radius: 6px;
            font-weight: 500;
        }

        .body-content {
            background: white;
            padding: 2rem;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            min-height: 80vh;
        }
    </style>
</head>
<body>

    @{
        var isAdmin = Session["AdminEmail"]?.ToString() == "kuldip1383@gmail.com";
        var isVisitor = Session["VisitorID"] != null;
        var isLoggedIn = isAdmin || isVisitor;
    }

    <div class="@(isLoggedIn ? "main-wrapper" : "")">

        @if (isLoggedIn)
        {
            <nav class="sidebar" id="sidebar">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h4 class="navbar-brand m-0">Corporate</h4>
                </div>

                <ul class="nav flex-column flex-grow-1">
                    @if (isAdmin)
                    {
                        <li><a class="nav-link" href="@Url.Action("AdminDashboard", "Admin")"><i class="bi bi-speedometer2 me-2"></i> Admindashboard</a></li>
                        <li><a class="nav-link" href="@Url.Action("Departments", "Admin")"><i class="bi bi-building me-2"></i> Departments</a></li>
                        <li><a class="nav-link" href="@Url.Action("RegisteredUsers", "Admin")"><i class="bi bi-people me-2"></i> Manage users</a></li>
                        <li><a class="nav-link" href="@Url.Action("PendingRequests", "Admin")"><i class="bi bi-clock-history me-2"></i> Pending request</a></li>
                        <li><a class="nav-link" href="@Url.Action("VisitHistory", "Admin")"><i class="bi bi-journal-text me-2"></i> User history</a></li>
                    }
                    else if (isVisitor)
                    {
                        <li><a class="nav-link" href="@Url.Action("CheckInOut", "Visitor")"><i class="bi bi-door-open me-2"></i> Check In/Out</a></li>
                        <li><a class="nav-link" href="@Url.Action("VisitHistory", "Visitor")"><i class="bi bi-journal-text me-2"></i> My history</a></li>
                        <li><a class="nav-link" href="@Url.Action("RevisitRequest", "Visitor")"><i class="bi bi-arrow-repeat me-2"></i> Revisit</a></li>
                    }
                </ul>
                <hr>
                <a href="@Url.Action("Logout", "Home")" class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                </a>
            </nav>
        }
        else
        {
            <nav class="navbar navbar-expand-sm navbar-light sticky-top w-100">
                <div class="container">
                    @Html.ActionLink("CorporatePortal", "HomeLanding", "Home", null, new { @class = "navbar-brand" })
                    <div class="collapse navbar-collapse">
                        <ul class="navbar-nav me-auto">
                            <li>@Html.ActionLink("Home", "HomeLanding", "Home", null, new { @class = "nav-link" })</li>
                            <li>@Html.ActionLink("Resources", "About", "Home", null, new { @class = "nav-link" })</li>
                            <li>@Html.ActionLink("Support", "Contact", "Home", null, new { @class = "nav-link" })</li>
                        </ul>
                        <div class="d-flex align-items-center">
                            @Html.ActionLink("Sign in", "Index", "Home", null, new { @class = "btn-login text-decoration-none me-3" })
                            @Html.ActionLink("Register", "Visitor_Registration", "Home", null, new { @class = "btn-register" })
                        </div>
                    </div>
                </div>
            </nav>
        }

        <div class="content-area">
            <div class="container-fluid">
                @if (isLoggedIn)
                {
                    <button class="toggle-btn" id="sidebarCollapse">
                        <i class="bi bi-list fs-4"></i>
                    </button>
                }

                <main role="main" class="body-content">
                    @RenderBody()
                </main>
                <footer class="text-center pb-4 mt-4">
                    <p>&copy; @DateTime.Now.Year - Professional Services Inc.</p>
                </footer>
            </div>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    <script>
        $(document).ready(function () {
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').toggleClass('collapsed');
            });
        });
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>