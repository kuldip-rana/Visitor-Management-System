<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Corporate Portal</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        :root {
            --primary-blue: #2563eb;
            --sidebar-bg: #ffffff;
            --top-header-height: 70px;
            --sidebar-width: 260px;
            --soft-bg: #f8fafc;
            --border-color: #e2e8f0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--soft-bg);
            margin: 0;
        }

        /* --- LOGGED IN LAYOUT --- */
        .wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        #sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border-color);
            transition: all 0.3s;
            z-index: 1040;
            position: fixed;
            height: 100vh;
        }

            #sidebar.collapsed {
                margin-left: calc(var(--sidebar-width) * -1);
            }

        .sidebar-header {
            padding: 20px;
            border-bottom: 1px solid var(--border-color);
        }

        /* Top Header */
        .top-header {
            height: var(--top-header-height);
            background: #fff;
            border-bottom: 1px solid var(--border-color);
            position: fixed;
            top: 0;
            right: 0;
            left: var(--sidebar-width);
            z-index: 1030;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 25px;
            transition: all 0.3s;
        }

        #sidebar.collapsed + .top-header {
            left: 0;
        }

        /* Main Content */
        .main-container {
            flex-grow: 1;
            margin-left: var(--sidebar-width);
            margin-top: var(--top-header-height);
            padding: 30px;
            transition: all 0.3s;
        }

        #sidebar.collapsed ~ .main-container {
            margin-left: 0;
        }

        /* Nav Links */
        .nav-link {
            color: #64748b !important;
            padding: 12px 15px;
            margin: 5px 15px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 500;
        }

            .nav-link:hover {
                background: #f1f5f9;
                color: var(--primary-blue) !important;
            }

            .nav-link.active {
                background: #eff6ff;
                color: var(--primary-blue) !important;
                font-weight: 600;
            }

        /* Profile Section */
        .profile-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            padding: 5px 12px;
            border-radius: 50px;
            border: 1px solid var(--border-color);
        }

            .profile-btn:hover {
                background: #f8fafc;
            }

        .avatar-box {
            width: 35px;
            height: 35px;
            background: var(--primary-blue);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }
    </style>
</head>
<body>

    @{
        var isAdmin = Session["AdminEmail"]?.ToString() == "kuldip1383@gmail.com";
        var isVisitor = Session["VisitorID"] != null;
        var isLoggedIn = isAdmin || isVisitor;
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    @if (!isLoggedIn)
    {
        @* --- GUEST NAVBAR --- *@
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom py-3">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary fs-4" href="#">CorporatePortal</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="HomeLanding">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-3">
                    <li class="nav-item">
                        @Html.ActionLink("About", "About", "Home", null, new { @class = "nav-link fw-medium" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Contact", "Contact", "Home", null, new { @class = "nav-link fw-medium" })
                    </li>
                    
                </ul>

                <div class="d-flex align-items-center gap-2">
                    @Html.ActionLink("Sign in", "Index", "Home", null, new { @class = "btn btn-link text-decoration-none text-dark fw-semibold" })
                    @Html.ActionLink("Register", "Visitor_Registration", "Home", null, new { @class = "btn btn-primary px-4 rounded-pill shadow-sm" })
                </div>
            </div>
        </div>
    </nav>
        <div class="container py-5">@RenderBody()</div>
    }
    else
    {
        <div class="wrapper">
            <nav id="sidebar">
                <div class="sidebar-header">
                    <h4 class="fw-bold text-primary mb-0">Corporate</h4>
                </div>
                <div class="nav flex-column mt-3">
                    @if (isAdmin)
                    {
                        <a class="nav-link @(currentAction == "AdminDashboard" ? "active" : "")" href="@Url.Action("AdminDashboard", "Admin")"><i class="bi bi-speedometer2"></i> Admindashboard</a>
                        <a class="nav-link @(currentAction == "Departments" ? "active" : "")" href="@Url.Action("Departments", "Admin")"><i class="bi bi-building"></i> Departments</a>
                        <a class="nav-link @(currentAction == "RegisteredUsers" ? "active" : "")" href="@Url.Action("RegisteredUsers", "Admin")"><i class="bi bi-people"></i> Manage users</a>
                        <a class="nav-link @(currentAction == "PendingRequests" ? "active" : "")" href="@Url.Action("PendingRequests", "Admin")"><i class="bi bi-clock-history"></i> Pending request</a>
                        <a class="nav-link @(currentAction == "VisitHistory" ? "active" : "")" href="@Url.Action("VisitHistory", "Admin")"><i class="bi bi-journal-text"></i> User history</a>
                    }
                    else if (isVisitor)
                    {
                        <a class="nav-link @(currentAction == "MyDashboard" ? "active" : "")" href="@Url.Action("MyDashboard", "Visitor")"><i class="bi bi-speedometer2"></i> My dashboard</a>
                        <a class="nav-link @(currentAction == "CheckInOut" ? "active" : "")" href="@Url.Action("CheckInOut", "Visitor")"><i class="bi bi-door-open"></i> Check In/Out</a>
                        <a class="nav-link @(currentAction == "VisitHistory" ? "active" : "")" href="@Url.Action("VisitHistory", "Visitor")"><i class="bi bi-journal-text"></i> My history</a>
                        <a class="nav-link @(currentAction == "RevisitRequest" ? "active" : "")" href="@Url.Action("RevisitRequest", "Visitor")"><i class="bi bi-arrow-repeat"></i> Revisit</a>
                    }
                </div>
            </nav>

            <header class="top-header">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-light" id="sidebarToggle"><i class="bi bi-list fs-4"></i></button>
                    <h5 class="mb-0 fw-bold text-dark d-none d-md-block">@ViewBag.Title</h5>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <div class="dropdown">
                        <div class="profile-btn dropdown-toggle" data-bs-toggle="dropdown">
                            <div class="avatar-box">@(isAdmin ? "A" : "V")</div>
                            <div class="d-none d-lg-block">
                                <p class="mb-0 small fw-bold">My Profile</p>
                                <p class="mb-0 smallest text-muted" style="font-size: 0.7rem;">@(isAdmin ? "Administrator" : "Visitor")</p>
                            </div>
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                            <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2"></i> Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 text-danger fw-bold" href="@Url.Action("Logout", "Home")"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <main class="main-container">
                <div class="bg-white p-4 rounded-4 shadow-sm border" style="min-height: 80vh;">
                    @RenderBody()
                </div>
                <footer class="mt-4 text-center text-muted small">
                    &copy; @DateTime.Now.Year - Professional Services Inc.
                </footer>
            </main>
        </div>
    }

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#sidebarToggle').on('click', function () {
                $('#sidebar').toggleClass('collapsed');
            });
        });
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>