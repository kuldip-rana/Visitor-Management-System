@model registar.Models.AdminDashboardViewModel
@{
    ViewBag.Title = "Admin Dashboard";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body {
        font-family: 'Inter', sans-serif;
        background-color: #f4f7fa;
        color: #334155;
    }

    /* Fix: Prevent internal scrollbars in cards */
    .dash-card {
        background: #fff;
        border: none;
        border-radius: 12px;
        transition: transform 0.2s;
        overflow: hidden !important; /* Stop the "drag" scrollbars */
        display: flex;
        flex-direction: column;
    }

        .dash-card:hover {
            transform: translateY(-5px);
        }

    .stat-label {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
    }

    .stat-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1e293b;
    }

    .icon-box {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    /* Soft Background Colors */
    .bg-soft-blue {
        background-color: #e0e7ff;
        color: #4338ca;
    }

    .bg-soft-orange {
        background-color: #ffedd5;
        color: #9a3412;
    }

    .bg-soft-green {
        background-color: #dcfce7;
        color: #15803d;
    }

    .bg-soft-red {
        background-color: #fee2e2;
        color: #b91c1c;
    }

    /* Fix: Stable container for Chart.js */
    .chart-wrapper {
        position: relative;
        width: 100%;
        flex-grow: 1; /* Allows it to fill the card space properly */
        min-height: 320px;
    }

    canvas {
        display: block;
        max-width: 100% !important;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Management Overview</h2>
        <span class="text-muted small">Updated: @DateTime.Now.ToString("MMM dd, yyyy HH:mm")</span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card dash-card shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-soft-blue me-3"><i class="fas fa-users"></i></div>
                    <div>
                        <div class="stat-label">Total Visits</div>
                        <div class="stat-value">@Model.TotalVisitors</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card dash-card shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-soft-orange me-3"><i class="fas fa-clock"></i></div>
                    <div>
                        <div class="stat-label">Pending</div>
                        <div class="stat-value text-warning">@Model.PendingCount</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card dash-card shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-soft-green me-3"><i class="fas fa-check-circle"></i></div>
                    <div>
                        <div class="stat-label">Approved</div>
                        <div class="stat-value text-success">@Model.ApprovedCount</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card dash-card shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-soft-red me-3"><i class="fas fa-times-circle"></i></div>
                    <div>
                        <div class="stat-label">Rejected</div>
                        <div class="stat-value text-danger">@Model.RejectedCount</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card dash-card shadow-sm p-4 h-100">
                <h5 class="fw-bold mb-4">Request Distribution</h5>
                <div class="chart-wrapper">
                    <canvas id="statusDoughnut"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card dash-card shadow-sm p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Activity Timeline</h5>
                    <select id="chartFilter" class="form-select form-select-sm" style="width: 200px;">
                        <option value="all">Show All Activity</option>
                        <option value="reg">Registrations Only</option>
                        <option value="login">Logins (OTP) Only</option>
                        <option value="check">Check-ins Only</option>
                    </select>
                </div>
                <div class="chart-wrapper">
                    <canvas id="timelineChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Global Config for all charts
    Chart.defaults.maintainAspectRatio = false;
    Chart.defaults.responsive = true;

    // 1. Initialize Doughnut Chart
    const statusCtx = document.getElementById('statusDoughnut').getContext('2d');
    new Chart(statusCtx, {
        type: 'doughnut',
        data: {
            labels: ['Pending', 'Approved', 'Rejected'],
            datasets: [{
                data: [@Model.PendingCount, @Model.ApprovedCount, @Model.RejectedCount],
                backgroundColor: ['#f59e0b', '#10b981', '#ef4444'],
                hoverOffset: 4,
                borderWidth: 0
            }]
        },
        options: {
            plugins: {
                legend: { position: 'bottom' }
            },
            cutout: '70%'
        }
    });

    // 2. Initialize Activity Timeline (Line Chart)
    const lineCtx = document.getElementById('timelineChart').getContext('2d');

    const labels = @Html.Raw(Json.Encode(Model.TimelineLabels));
    const regData = @Html.Raw(Json.Encode(Model.RegistrationData));
    const loginData = @Html.Raw(Json.Encode(Model.LoginData));
    const checkData = @Html.Raw(Json.Encode(Model.CheckInData));

    let timelineChart = new Chart(lineCtx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [
                {
                    id: 'reg',
                    label: 'Registrations',
                    data: regData,
                    borderColor: '#4338ca',
                    backgroundColor: 'rgba(67, 56, 202, 0.1)',
                    fill: true,
                    tension: 0.4
                },
                {
                    id: 'login',
                    label: 'Logins (OTP)',
                    data: loginData,
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16, 185, 129, 0.1)',
                    fill: true,
                    tension: 0.4
                },
                {
                    id: 'check',
                    label: 'Check-ins',
                    data: checkData,
                    borderColor: '#f59e0b',
                    backgroundColor: 'rgba(245, 158, 11, 0.1)',
                    fill: true,
                    tension: 0.4
                }
            ]
        },
        options: {
            plugins: {
                legend: { display: true, position: 'top' }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: '#f1f5f9' }
                },
                x: {
                    grid: { display: false }
                }
            }
        }
    });

    // 3. Dropdown Filter Logic
    document.getElementById('chartFilter').addEventListener('change', function() {
        const selection = this.value;

        timelineChart.data.datasets.forEach((dataset) => {
            if (selection === 'all') {
                dataset.hidden = false;
            } else {
                dataset.hidden = (dataset.id !== selection);
            }
        });

        timelineChart.update();
    });
</script>