@model IEnumerable<registar.Models.Visitor>

@{
    ViewBag.Title = "Pending Requests";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Inter', sans-serif;
        background-color: #f8fafc;
        color: #1e293b;
    }

    .page-header {
        background: white;
        padding: 1.5rem 2rem;
        border-bottom: 1px solid #e2e8f0;
        margin-bottom: 2rem;
    }

    .card-table {
        background: white;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }

    .table thead {
        background-color: #f8fafc;
    }

        .table thead th {
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            border: none;
            padding: 1.25rem 1rem;
        }

    .table tbody td {
        vertical-align: middle;
        padding: 1.25rem 1rem;
        border-bottom: 1px solid #f1f5f9;
    }

    /* Fixed Status Badge UI */
    .badge-pending {
        display: inline-flex;
        align-items: center;
        background-color: #fffbeb;
        color: #92400e;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.75rem;
        border: 1px solid #fef3c7;
        white-space: nowrap;
    }

    .btn-action {
        font-weight: 600;
        font-size: 0.85rem;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition: all 0.2s;
        border: none;
    }

    .btn-approve {
        background-color: #10b981;
        color: white;
    }

        .btn-approve:hover {
            background-color: #059669;
            transform: translateY(-1px);
            box-shadow: 0 4px 6px -1px rgba(16, 185, 129, 0.2);
        }

    .btn-reject {
        background-color: #fee2e2;
        color: #dc2626;
    }

        .btn-reject:hover {
            background-color: #fecaca;
            color: #b91c1c;
            transform: translateY(-1px);
        }

    .visitor-name {
        font-weight: 600;
        color: #0f172a;
        font-size: 0.95rem;
    }

    .dept-label {
        color: #4338ca;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .visitor-meta {
        font-size: 0.8rem;
        color: #64748b;
    }

    .gap-2 {
        gap: 0.5rem !important;
    }
</style>

<div class="page-header shadow-sm">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1" style="color: #1e293b;">Pending Visit Requests</h2>
                <p class="text-muted mb-0">Review and authorize incoming visitors.</p>
            </div>
            <a href="@Url.Action("AdminDashboard", "Admin")" class="btn btn-outline-primary btn-sm px-3">
                <i class="fas fa-arrow-left me-2"></i>Dashboard
            </a>
        </div>
    </div>
</div>

<div class="container-fluid px-4 pb-5">
    <div class="card-table shadow-sm">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Visitor Information</th>
                        <th>Contact Details</th>
                        <th>Department / Purpose</th>
                        <th>Date & Time</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Decision</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fas fa-clipboard-check fa-3x mb-3 opacity-25"></i>
                                <p class="mb-0">All clear! No pending requests found.</p>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="visitor-name">@item.Name</div>
                                <div class="visitor-meta">Ref: #@item.Id</div>
                            </td>
                            <td>
                                <div style="font-size: 0.85rem; font-weight: 500;">@item.Email</div>
                                <div class="visitor-meta">@item.Phone</div>
                            </td>
                            <td>
                                @* FIX: Handling the Department Proxy string *@
                                <div class="dept-label">
                                    @(item.Department != null ? item.Department.Name : "N/A")
                                </div>
                                <div class="visitor-meta">@item.Purpose</div>
                            </td>
                            <td>
                                @if (item.RegisteredAt.HasValue)
                                {
                                    <div style="font-weight: 500;">@item.RegisteredAt.Value.ToString("MMM dd, yyyy")</div>
                                    <div class="visitor-meta">@item.RegisteredAt.Value.ToString("hh:mm tt")</div>
                                }
                                else
                                { <span class="text-muted">--</span>}
                            </td>
                            <td>
                                <span class="badge-pending">
                                    <i class="fas fa-spinner fa-spin me-2" style="font-size: 0.7rem;"></i>Pending
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    @using (Html.BeginForm("UpdateStatus", "Admin", FormMethod.Post, new { @style = "display:inline;" }))
                                    {
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="status" value="2" />
                                        <button type="submit" class="btn-action btn-approve" onclick="return confirm('Authorize this entry?')">
                                            Approve
                                        </button>
                                    }
                                    @using (Html.BeginForm("UpdateStatus", "Admin", FormMethod.Post, new { @style = "display:inline;" }))
                                    {
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="status" value="3" />
                                        <button type="submit" class="btn-action btn-reject" onclick="return confirm('Deny this entry request?')">
                                            Reject
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>