@model IEnumerable<registar.Models.Visitor>
@{
    ViewBag.Title = "Manage Users";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-people-fill text-primary"></i> Registered Users</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 mb-4 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Last Known Name</th>
                        <th>Email (Gmail)</th>
                        <th>Registered On</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="fw-bold">@user.Name</td>
                            <td>@user.Email</td>
                            <td>
                                @* Null-safe date formatting *@
                                @(user.RegisteredAt.HasValue
                    ? user.RegisteredAt.Value.ToString("MMM dd, yyyy")
                    : "N/A")
                            </td>
                            <td class="text-center">
                                @using (Html.BeginForm("DeleteUserByEmail", "Admin", FormMethod.Post, new
                                {
                                    onsubmit = "return confirm('Warning: This will delete ALL visit history and active passes for this email. Continue?');",
                                    @class = "d-inline" // Keeps the form from adding extra block-level spacing
                                }))
                                {
                                    @Html.AntiForgeryToken()
                                    @* Use name="email" to match your Controller's parameter exactly *@
                                    <input type="hidden" name="email" value="@user.Email" />

                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                        <i class="bi bi-trash3-fill me-1"></i> Delete User
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>