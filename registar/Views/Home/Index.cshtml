@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <title>Login | VMS Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
</head>

<body class="bg-slate-50 flex items-center justify-center min-h-screen p-4">
    <div class="max-w-md w-full bg-white rounded-[24px] p-8 md:p-10 shadow-xl border border-slate-100 relative">

        <div class="mb-6">
            <a href="@Url.Action("HomeLanding", "Home")" class="inline-flex items-center text-xs font-semibold text-slate-400 hover:text-blue-600 transition-colors">
                <i class="bi bi-house-door-fill me-2"></i>
                Back to Home Landing
            </a>
        </div>
        <div class="text-center mb-8">
            <div class="bg-blue-50 text-blue-600 w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-shield-lock-fill text-3xl"></i>
            </div>
            <h2 class="text-2xl font-bold text-slate-800">VMS Portal</h2>
            <p id="status-text" class="text-slate-500 text-sm">Verify your identity to continue</p>
        </div>
        @if (ViewBag.Error != null)
        {
            <div id="server-error" class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-xl text-sm mb-6 animate__animated animate__shakeX shadow-sm">
                <div class="flex items-center">
                    <i class="bi bi-exclamation-octagon-fill text-lg me-3"></i>
                    <div>
                        <p class="font-bold">Login Failed</p>
                        <p>@ViewBag.Error</p>
                    </div>
                </div>
            </div>
        }

        <div id="error-alert" class="hidden bg-red-50 text-red-600 p-3 rounded-xl text-xs mb-6 animate__animated animate__shakeX flex items-center gap-2">
            <i class="bi bi-exclamation-triangle-fill"></i> <span id="error-message"></span>
        </div>

        <div id="error-alert" class="hidden bg-red-50 text-red-600 p-3 rounded-xl text-xs mb-6 animate__animated animate__shakeX flex items-center gap-2">
            <i class="bi bi-exclamation-triangle-fill"></i> <span id="error-message"></span>
        </div>

        @using (Html.BeginForm("VerifyLogin", "Home", FormMethod.Post, new { id = "loginForm", @class = "space-y-6" }))
        {
            @Html.AntiForgeryToken()

            @* CRITICAL: This hidden field passes the email to Step 2 *@
            <input type="hidden" id="hiddenEmail" name="email" />

            <div id="email-section">
                <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2">Email Address</label>
                <div class="flex items-center border border-slate-200 rounded-xl px-4 bg-white focus-within:border-blue-500 transition-all">
                    <i class="bi bi-envelope text-slate-400"></i>
                    <input type="email" id="emailInput" required placeholder="kuldip1383@gmail.com"
                           class="w-full py-4 pl-3 outline-none text-slate-700 bg-transparent" />
                </div>
                <button type="button" id="btn-send-otp" class="w-full mt-6 bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-blue-100 flex justify-center items-center">
                    <span id="btn-text">Get Login Code</span>
                    <div id="btn-spinner" class="hidden animate-spin h-5 w-5 border-2 border-white border-t-transparent rounded-full ms-2"></div>
                </button>
            </div>

            <div id="otp-section" class="hidden animate__animated animate__fadeInUp">
                <div class="text-center mb-4">
                    <span class="text-xs text-blue-600 font-semibold bg-blue-50 px-3 py-1 rounded-full">
                        Code sent to <span id="display-email"></span>
                    </span>
                </div>
                <label class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2 text-center">6-Digit Code</label>
                <input type="text" name="otp" maxlength="6" required
                       class="w-full py-4 text-center text-3xl tracking-[0.5em] font-bold border border-slate-200 rounded-xl outline-none focus:border-blue-500 bg-slate-50"
                       placeholder="000000" />

                <button type="submit" class="w-full mt-6 bg-green-600 hover:bg-green-700 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-green-100">
                    Verify & Login
                </button>

                <button type="button" onclick="location.reload()" class="w-full mt-3 text-xs text-slate-400 hover:text-blue-600 transition-colors">
                    <i class="bi bi-arrow-left"></i> Change Email
                </button>
            </div>
        }
    </div>

    <script>
        $(document).ready(function () {
            $("#btn-send-otp").click(function () {
                var emailVal = $("#emailInput").val();
                if (!emailVal) { alert("Please enter email"); return; }

                // Show Loading
                $("#btn-text").text("Checking...");
                $("#btn-spinner").removeClass("hidden");
                $("#error-alert").addClass("hidden");

                $.ajax({
                    url: '@Url.Action("SendOtp", "Home")',
                    type: 'POST',
                    data: { email: emailVal },
                    success: function (response) {
                        if (response.success) {
                            $("#hiddenEmail").val(emailVal); // SET THE HIDDEN EMAIL
                            $("#email-section").addClass("hidden");
                            $("#otp-section").removeClass("hidden");
                            $("#display-email").text(emailVal);
                            $("#status-text").text("Check your inbox");
                        } else {
                            $("#error-message").text(response.message);
                            $("#error-alert").removeClass("hidden");
                            $("#btn-text").text("Get Login Code");
                            $("#btn-spinner").addClass("hidden");
                        }
                    },
                    error: function () {
                        $("#error-message").text("Connection error.");
                        $("#error-alert").removeClass("hidden");
                        $("#btn-text").text("Get Login Code");
                        $("#btn-spinner").addClass("hidden");
                    }
                });
            });
        });
    </script>
</body>
</html>