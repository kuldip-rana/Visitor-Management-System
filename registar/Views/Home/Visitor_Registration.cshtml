@model registar.Models.Visitor

@{
    ViewBag.Title = "Visitor Entry";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --primary: #2563eb;
        --primary-hover: #1d4ed8;
        --error: #e11d48;
        --bg-soft: #f8fafc;
        --border-color: #e2e8f0;
        --text-main: #0f172a;
        --text-muted: #64748b;
    }

    body {
        background-color: #f1f5f9;
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--text-main);
    }

    .registration-card {
        background: #ffffff;
        border-radius: 16px;
        border: 1px solid var(--border-color);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04);
        padding: 3rem !important;
    }

    .form-label {
        font-weight: 600;
        color: var(--text-main);
        font-size: 0.85rem;
        margin-bottom: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.025em;
    }

    .input-group-text {
        background-color: var(--bg-soft);
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        padding: 0.75rem 1rem;
    }

    .form-control, .form-select {
        border: 1px solid var(--border-color);
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        color: var(--text-main);
        transition: all 0.2s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
            background-color: #fff;
        }

    /* Tabs Styling */
    .nav-pills {
        background: var(--bg-soft);
        padding: 5px;
        border-radius: 12px;
        border: 1px solid var(--border-color);
    }

        .nav-pills .nav-link {
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.9rem;
            border-radius: 8px;
            padding: 10px 20px;
            transition: 0.3s;
        }

            .nav-pills .nav-link.active {
                background-color: #fff !important;
                color: var(--primary) !important;
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            }

    /* Validation UI */
    .field-validation-error {
        color: var(--error);
        font-size: 0.75rem;
        font-weight: 600;
        margin-top: 5px;
        display: block;
    }

    .input-validation-error {
        border-color: var(--error) !important;
    }

    .is-invalid-group .input-group-text {
        border-color: var(--error) !important;
        color: var(--error);
    }

    .btn-submit {
        background-color: var(--primary);
        border: none;
        padding: 1rem;
        font-weight: 700;
        border-radius: 12px;
        transition: all 0.2s ease;
        letter-spacing: 0.05em;
    }

        .btn-submit:hover {
            background-color: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.2);
        }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="registration-card">
                <div class="text-center mb-5">
                    <h2 class="fw-bold">Visitor Registration</h2>
                    <p class="text-muted">Fill in the details to generate your security pass.</p>
                </div>

                @using (Html.BeginForm("Visitor_Registration", "Home", FormMethod.Post, new { enctype = "multipart/form-data", id = "regForm" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <label class="form-label">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "user_name@domain.com", id = "vEmail" })
                            </div>
                            @Html.ValidationMessageFor(m => m.Email)
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Department</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-building"></i></span>
                                @Html.DropDownListFor(m => m.DepartmentId, (SelectList)ViewBag.DepartmentId, "Select", new { @class = "form-select" })
                            </div>
                            @Html.ValidationMessageFor(m => m.DepartmentId)
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Visit Date</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-calendar-check"></i></span>
                                @Html.TextBoxFor(m => m.VisitDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                            </div>
                            @Html.ValidationMessageFor(m => m.VisitDate)
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Purpose of Visit</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-chat-left-text"></i></span>
                                @Html.TextBoxFor(m => m.Purpose, new { @class = "form-control", placeholder = "e.g. Client Meeting" })
                            </div>
                            @Html.ValidationMessageFor(m => m.Purpose)
                        </div>
                    </div>

                    <ul class="nav nav-pills mb-4" role="tablist">
                        <li class="nav-item flex-fill text-center">
                            <button class="nav-link active w-100" id="single-tab" data-bs-toggle="pill" data-bs-target="#single" type="button" role="tab">Individual Entry</button>
                        </li>
                        <li class="nav-item flex-fill text-center">
                            <button class="nav-link w-100" id="group-tab" data-bs-toggle="pill" data-bs-target="#group" type="button" role="tab">CSV Bulk Upload</button>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="single" role="tabpanel">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="form-label">Visitor Full Name</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control", id = "vName", placeholder = "John Doe" })
                                    </div>
                                    @Html.ValidationMessageFor(m => m.Name)
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Mobile Number</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="bi bi-phone"></i></span>
                                        @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", id = "vPhone", maxlength = "10" })
                                    </div>
                                    @Html.ValidationMessageFor(m => m.Phone)
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="group" role="tabpanel">
                            <div class="p-5 border-2 border-dashed rounded-4 text-center bg-light">
                                <i class="bi bi-cloud-upload fs-1 text-primary mb-3 d-block"></i>
                                <input type="file" name="csvFile" id="csvFile" class="form-control" accept=".csv" />
                                <p class="text-muted mt-3 small">Format: <strong>Name, Phone</strong> headers required.</p>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5">
                        <button type="submit" class="btn btn-primary btn-submit w-100 text-white shadow">
                            REGISTER & GENERATE PASS
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

<script>
    $(document).ready(function () {
        const $form = $('#regForm');

        // Force Email Lowercase and block spaces
        $('#vEmail').on('input', function () {
            this.value = this.value.toLowerCase().replace(/\s/g, '');
        });

        // Block everything except alphabets and spaces for Name
        $('#vName').on('input', function () {
            this.value = this.value.replace(/[^a-zA-Z\s]/g, '');
        });

        // Block non-numeric for Phone
        $('#vPhone').on('input', function () {
            this.value = this.value.replace(/[^0-9]/g, '');
        });

        // Tab dynamic validation logic
        $('#group-tab').on('click', function () {
            $('#vName, #vPhone').rules('remove', 'required');
            $('#csvFile').rules('add', { required: true });
        });

        $('#single-tab').on('click', function () {
            $('#vName, #vPhone').rules('add', { required: true });
            $('#csvFile').rules('remove', 'required');
        });

        // Submit Guard
        $form.on('submit', function (e) {
            let emailVal = $('#vEmail').val().trim();
            // Strict Regex: chars/underscores +  + chars/underscores + dot + chars
            let emailPattern = /^[a-zA-Z0-9_]+@@[a-zA-Z0-9_]+\.[a-zA-Z]{2,}$/;

            if (emailVal !== "" && !emailPattern.test(emailVal)) {
                e.preventDefault();
                alert("Please enter a valid email. Only letters, numbers and underscores are allowed. Must include '' and '.'");
                $('#vEmail').focus();
                return false;
            }

            if (!$form.valid()) {
                e.preventDefault();
                $('.input-validation-error').closest('.input-group').addClass('is-invalid-group');
                return false;
            }
        });
    });
</script>